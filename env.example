# 游戏数据：compose 默认将当前目录挂载为容器 /server，无需额外变量。
# 可选 SERVER_SEED=/path/to/seed 从只读目录首次灌入或同步部分插件配置（一般不需要）。

MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=newsky
MYSQL_USER=newsky
MYSQL_PASSWORD=changeme
MYSQL_ROOT_PASSWORD=root

PUBLISH_PORT=25565
RCON_PUBLISH_PORT=25575
MC_SERVER_PORT=25565
MYSQL_PUBLISH_PORT=33060

# 数据库 schema 需在本机手动执行: ./init-db.sh（需安装 mysql 客户端）。
# 从宿主机连 Compose 内的 MySQL 时，请在用于执行脚本的 .env 或环境中使用可路由地址，
# 例如 MYSQL_HOST=127.0.0.1、MYSQL_PORT 与 MYSQL_PUBLISH_PORT 映射一致（如 33060）。
